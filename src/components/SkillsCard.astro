---
// Props que recibe el componente
const { name, icon } = Astro.props;
---

<div class="flex items-center gap-2 border border-gray-300 dark:border-gray-600 rounded px-4 py-2 font-medium transition-all bg-white dark:bg-[#0f2b3b] hover:border-gray-400 dark:hover:border-gray-500 hover:-translate-y-0.5 hover:shadow-md dark:hover:shadow-lg dark:hover:shadow-blue-500/10">
  <img src={icon} alt={name} class="w-5 h-5 dark:filter dark:invert" />
  <span class="text-gray-900 dark:text-white">{name}</span>
</div>
