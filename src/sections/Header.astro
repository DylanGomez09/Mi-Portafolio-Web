  <!-- Mobile menu -->
  <div id="mobile-menu" class="hidden md:hidden">
    <div
      class="max-w-[1200px] mx-auto bg-white/95 dark:bg-[#071427] rounded-b-lg shadow-md"
    >
      <nav class="flex flex-col gap-1 p-4" aria-label="Menú móvil">
        <a
          href="#home"
          data-nav="#home"
          class="block py-2 px-3 rounded nav-link-mobile text-gray-700 dark:text-white hover:bg-gray-100 dark:hover:bg-[#0f2b3b] transition"
          >Inicio</a
        >
        <a
          href="#about"
          data-nav="#about"
          class="block py-2 px-3 rounded nav-link-mobile text-gray-700 dark:text-white hover:bg-gray-100 dark:hover:bg-[#0f2b3b] transition"
          >Sobre mí</a
        >
        <a
          href="#skills"
          data-nav="#skills"
          class="block py-2 px-3 rounded nav-link-mobile text-gray-700 dark:text-white hover:bg-gray-100 dark:hover:bg-[#0f2b3b] transition"
          >Habilidades</a
        >
        <a
          href="#projects"
          data-nav="#projects"
          class="block py-2 px-3 rounded nav-link-mobile text-gray-700 dark:text-white hover:bg-gray-100 dark:hover:bg-[#0f2b3b] transition"
          >Proyectos</a
        >
        <a
          href="#contact"
          data-nav="#contact"
          class="block py-2 px-3 rounded nav-link-mobile text-gray-700 dark:text-white hover:bg-gray-100 dark:hover:bg-[#0f2b3b] transition"
          >Contacto</a
        >

        <div class="flex items-center gap-3 pt-2">
          <a
            href="https://github.com/DylanGomez09"
            target="_blank"
            rel="noopener noreferrer"
            class="p-2 rounded bg-[#E5EDF5]/90 dark:bg-transparent"
            aria-label="Github"
          >
            <img
              src="/icons/github.svg"
              alt="GitHub"
              class="w-4 h-4 dark:filter dark:invert"
            />
          </a>
          <a
            href="https://www.linkedin.com/in/dylangomez09/"
            target="_blank"
            rel="noopener noreferrer"
            class="p-2 rounded bg-[#E5EDF5]/90 dark:bg-transparent"
            aria-label="LinkedIn"
          >
            <img
              src="/icons/linkedin.svg"
