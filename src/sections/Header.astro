</header>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    const menuBtn = document.getElementById("menu-button");
    const mobileMenu = document.getElementById("mobile-menu");

    // ========== MENÚ MÓVIL ==========
    function openMenu() {
      mobileMenu?.classList.remove("hidden");
      menuBtn?.setAttribute("aria-expanded", "true");
    }

    function closeMenu() {
      mobileMenu?.classList.add("hidden");
      menuBtn?.setAttribute("aria-expanded", "false");
    }

    function toggleMenu() {
      const isOpen = menuBtn?.getAttribute("aria-expanded") === "true";
      if (isOpen) {
        closeMenu();
      } else {
        openMenu();
      }
    }

    menuBtn?.addEventListener("click", toggleMenu);

    // Cerrar menú al hacer clic en un enlace
    mobileMenu?.querySelectorAll("a[data-nav]").forEach((link) => {
      link.addEventListener("click", closeMenu);
    });

    // Cerrar menú al redimensionar a desktop
    window.addEventListener("resize", () => {
      if (window.innerWidth >= 768) {
        closeMenu();
      }
    });

    // ========== SCROLL SPY ==========
    const navLinks = document.querySelectorAll("a[data-nav]");

    if (navLinks.length && "IntersectionObserver" in window) {
      // Crear un mapa de secciones a Enlaces
      const sectionToLink = new Map();

      navLinks.forEach((link) => {
        // Obtener el ID de la sección desde data-nav (ej: "#home" -> "home")
        const navValue = link.getAttribute("data-nav");
        if (!navValue) return;

        const sectionId = navValue.startsWith("#")
          ? navValue.slice(1)
          : navValue;
        const section = document.getElementById(sectionId);

        if (section) {
          sectionToLink.set(sectionId, link);
        }
      });

      if (sectionToLink.size === 0) return; // Si no hay secciones válidas, salir

      // Crear el observador
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              const activeSectionId = entry.target.id;

              // Remover clases de todos los enlaces
              navLinks.forEach((l) => {
                l.classList.remove("text-blue-600", "font-semibold");
              });

              // Agregar clases al enlace activo
              const activeLink = sectionToLink.get(activeSectionId);
              if (activeLink) {
                activeLink.classList.add("text-blue-600", "font-semibold");
              }
            }
          });
        },
        { threshold: 0.5 }
      );

      // Observar todas las secciones
      sectionToLink.forEach((link, sectionId) => {
        const section = document.getElementById(sectionId);
        if (section) {
          observer.observe(section);
        }
      });
    }
  });

  const btnLight = document.getElementById("bottomLight")!;
  const btnDark = document.getElementById("bottomDark")!;
  const btnLightMobile = document.getElementById("bottomLight-mobile")!;
  const btnDarkMobile = document.getElementById("bottomDark-mobile")!;

  btnLight.addEventListener("click", (e) => {
    e.preventDefault();

    document.documentElement.classList.remove("dark");

    localStorage.setItem("color-scheme", "light");
  });

  btnDark.addEventListener("click", (e) => {
    e.preventDefault();

    document.documentElement.classList.add("dark");

    localStorage.setItem("color-scheme", "dark");
  });

    btnLightMobile.addEventListener("click", (e) => {
      e.preventDefault();

    document.documentElement.classList.remove("dark");

    localStorage.setItem("color-scheme", "light");
  });

  btnDarkMobile.addEventListener("click", (e) => {
    e.preventDefault();
    
    document.documentElement.classList.add("dark");

    localStorage.setItem("color-scheme", "dark");
  });
</script>
